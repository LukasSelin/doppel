#!/usr/bin/env bash
#
# pre-commit hook: gofmt check + go vet

set -euo pipefail

echo "pre-commit: checking gofmt..."

# Find staged .go files (only Added/Copied/Modified/Renamed, not Deleted)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.go')

if [ -n "$STAGED_GO_FILES" ]; then
    UNFORMATTED=$(echo "$STAGED_GO_FILES" | xargs gofmt -l 2>&1)
    if [ -n "$UNFORMATTED" ]; then
        echo "ERROR: the following files are not gofmt'd:"
        echo "$UNFORMATTED"
        echo ""
        echo "Run: task fmt"
        exit 1
    fi
fi

echo "pre-commit: running go vet..."
go vet ./...

echo "pre-commit: OK"
